% iclr2027_conference.sty — faithful ICLR-style single-column format (self-contained).
% Reproduces the ICLR look: Times text, ~1in margins (6.5in text block), running header,
% ruled abstract, and numbered sans-bold section headings. Use \iclrfinalcopy for camera-ready.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{iclr2027_conference}[2027 ICLR conference style (local faithful build)]

\RequirePackage{geometry}
\geometry{letterpaper, top=1in, bottom=1in, left=1in, right=1in, headsep=0.3in, headheight=14pt}

\RequirePackage{times}
\RequirePackage{mathptmx}
\RequirePackage[T1]{fontenc}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}

% ---- running header: "Under review as a conference paper at ICLR 2027" ----
\newif\if@iclrfinal\@iclrfinalfalse
\def\iclrfinalcopy{\@iclrfinaltrue}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[C]{\if@iclrfinal\else\normalfont\small Under review as a conference paper at ICLR 2027\fi}
\fancyfoot[C]{\normalfont\small\thepage}
\fancypagestyle{plain}{\fancyhf{}%
  \fancyhead[C]{\if@iclrfinal\else\normalfont\small Under review as a conference paper at ICLR 2027\fi}%
  \fancyfoot[C]{\normalfont\small\thepage}}

% ---- title block ----
\renewcommand{\@maketitle}{%
  \newpage\null\vskip 0.3em%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.2em%
    {\large\lineskip .5em \begin{tabular}[t]{c}\@author\end{tabular}\par}%
  \end{center}%
  \vskip 1.0em}

% ---- abstract: centered heading + horizontal rules, slightly narrowed ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.4em}%
  \begin{quote}\rule{\linewidth}{0.4pt}\par\vspace{0.4em}\small}%
  {\par\vspace{0.4em}\rule{\linewidth}{0.4pt}\end{quote}}

% ---- section headings: bold, sans, ICLR-like sizes ----
\titleformat{\section}{\large\bfseries\sffamily}{\thesection}{0.6em}{}
\titleformat{\subsection}{\normalsize\bfseries\sffamily}{\thesubsection}{0.6em}{}
\titleformat{\subsubsection}{\normalsize\bfseries\sffamily}{\thesubsubsection}{0.6em}{}
\titlespacing*{\section}{0pt}{1.2em}{0.5em}
\titlespacing*{\subsection}{0pt}{0.9em}{0.4em}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}
\renewcommand{\baselinestretch}{1.0}

\endinput
